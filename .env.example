# ===== BTG Robotics Foundation - Environment Variables =====

# Security
SECRET_KEY=generate-a-random-secret-key-here

# Database
# For development (SQLite - no config needed):
# DATABASE_URL=sqlite:///data/btg.db
#
# For production (PostgreSQL):
# DATABASE_URL=postgresql://user:password@host:5432/dbname
#
# Popular hosted PostgreSQL providers:
# - Vercel Postgres: postgresql://... (get from Vercel dashboard)
# - Neon: postgresql://... (get from neon.tech)
# - Supabase: postgresql://... (get from supabase.com)
# - Render: postgresql://... (get from render.com)

# Seed credentials (only used if DB is empty on first run)
BTG_ADMIN_EMAIL=admin@bridgethegaprobotics.org
BTG_ADMIN_PASSWORD=your-secure-admin-password
BTG_PRESIDENT_PASSWORD=your-secure-president-password

# Platform detection (auto-set by Vercel/Netlify/AWS)
# VERCEL=1
# NETLIFY=1
# AWS_LAMBDA_FUNCTION_NAME=
